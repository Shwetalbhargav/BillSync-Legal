NODE_ENV=staging
PORT=5000
MONGODB_URI=${STAGING_MONGODB_URI}
JWT_SECRET=${STAGING_JWT_SECRET}
FRONTEND_URL=https://staging.lexora.example
CORS_ORIGINS=https://staging.lexora.example
ALLOWED_EXTENSION_IDS=${STAGING_EXTENSION_IDS}
PAYMENT_MOCK_GATEWAY_ENABLED=false
AUTH_COOKIE_SECURE=true
SMTP_HOST=${STAGING_SMTP_HOST}
SMTP_PORT=587
SMTP_USER=${STAGING_SMTP_USER}
SMTP_PASS=${STAGING_SMTP_PASS}
OPS_SHARED_TOKEN=${STAGING_OPS_SHARED_TOKEN}
SENTRY_DSN=${STAGING_SENTRY_DSN}
BACKUP_ENCRYPTION_KEY_REF=${STAGING_BACKUP_KMS_KEY}
SECRET_SERVICE_PROVIDER=github-actions
