NODE_ENV=production
PORT=5000
MONGODB_URI=${PRODUCTION_MONGODB_URI}
JWT_SECRET=${PRODUCTION_JWT_SECRET}
FRONTEND_URL=https://app.lexora.example
CORS_ORIGINS=https://app.lexora.example
ALLOWED_EXTENSION_IDS=${PRODUCTION_EXTENSION_IDS}
PAYMENT_MOCK_GATEWAY_ENABLED=false
AUTH_COOKIE_SECURE=true
SMTP_HOST=${PRODUCTION_SMTP_HOST}
SMTP_PORT=587
SMTP_USER=${PRODUCTION_SMTP_USER}
SMTP_PASS=${PRODUCTION_SMTP_PASS}
ZOHO_CLIENT_ID=${PRODUCTION_ZOHO_CLIENT_ID}
ZOHO_CLIENT_SECRET=${PRODUCTION_ZOHO_CLIENT_SECRET}
ZOHO_REDIRECT_URI=https://billsync-legal.onrender.com/api/integrations/zoho/callback
ZOHO_ACCOUNTS_SERVER=https://accounts.zoho.in
ZOHO_SCOPES=ZohoCRM.modules.ALL,ZohoCRM.settings.ALL
OPS_SHARED_TOKEN=${PRODUCTION_OPS_SHARED_TOKEN}
SENTRY_DSN=${PRODUCTION_SENTRY_DSN}
BACKUP_ENCRYPTION_KEY_REF=${PRODUCTION_BACKUP_KMS_KEY}
SECRET_SERVICE_PROVIDER=managed-secret-service
