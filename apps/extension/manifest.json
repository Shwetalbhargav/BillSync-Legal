{
  "manifest_version": 3,
  "name": "BillSync Legal Billables Capture",
  "short_name": "BillSync Capture",
  "version": "1.0.1",
  "description": "Track billable Gmail and research time for BillSync legal workflows.",
  "minimum_chrome_version": "116",
  "permissions": ["scripting", "activeTab", "storage", "alarms"],
  "action": {
    "default_title": "Capture Legal Billable"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "type": "module",
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "host_permissions": 
  ["https://mail.google.com/*",
   "http://127.0.0.1:5000/*",
   "http://localhost:5000/*",
   "https://legalbillind-backend.onrender.com/*",
    "https://bill-bot-legal.vercel.app/*" ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["gmailAdapter.js", "captureCore.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
