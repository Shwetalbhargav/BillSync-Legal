{
  "name": "legal-billing",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": "22.16.x",
    "npm": ">=10"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "vitest run",
    "test:release-hardening": "vitest run src/__tests__/productionHardening.test.js src/__tests__/workspaceIsolation.test.js src/__tests__/workspaceFoundation.test.js src/__tests__/subscriptionFeatureService.test.js src/__tests__/rbacPolicyService.test.js src/__tests__/moduleNavigationService.test.js",
    "test:workspace-isolation": "vitest run src/__tests__/workspaceIsolation.test.js src/__tests__/twoWorkspaceSecurity.test.js --passWithNoTests",
    "test:financial": "vitest run src/__tests__/financialCorrectness.test.js src/__tests__/paymentFinance.test.js src/__tests__/invoiceStatus.test.js",
    "lint": "node --check server.js && node --check src/app.js",
    "audit": "npm audit --audit-level=high",
    "migrate": "node src/scripts/migrate.js up",
    "migrate:down": "node src/scripts/migrate.js down",
    "migrate:status": "node src/scripts/migrate.js status",
    "migrate:workspace-ids": "node src/scripts/migrateWorkspaceIds.js",
    "migrate:commercial-roles": "node src/scripts/migrateCommercialRoles.js",
    "seed:workspace-foundation": "node src/scripts/seedWorkspaceFoundation.js",
    "seed:fresh-sample": "node src/seeds/seedFreshSampleData.js",
    "validate:workspace-foundation": "node src/scripts/validateWorkspaceFoundation.js",
    "seed:dev": "node src/seeds/seedDevData.js",
    "seed:firm": "node src/seeds/seedFirm.js",
    "seed:veeresh-demo": "node src/seeds/seedVeereshDemoData.js"
  },
