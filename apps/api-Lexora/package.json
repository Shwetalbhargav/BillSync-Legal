    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.18.0",
    "mongoose": "^8.16.4",
    "morgan": "^1.10.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^9.0.1",
    "openai": "^5.11.0",
    "pdf-parse": "^2.4.5",
    "qs": "^6.14.0",
    "router": "^2.2.0"
  },
